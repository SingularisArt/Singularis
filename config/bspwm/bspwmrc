xrdb ~/.Xresources &
picom -b --experimental-backends --backend glx --blur-method dual_kawase &
hsetroot -cover ~/.config/wall.png &
flameshot &
fcitx -d &
launchpolybar &
killall bspswallow
pidof bspswallow | bspswallow &
feh --bg-scale ~/.config/wall.jpg &
"$HOME/.config/polybar/launch.sh" &

